# ── Aether Studio Environment Variables ──────────────────────────────────────

# Gemini AI API Key (optional — only needed for AI background generator and AI director)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server port (default: 3001)
PORT=3001

# Node environment (production/development)
NODE_ENV=production

# Socket.io auth token (auto-generated if not set — set this for production)
# Generate one with: node -e "console.log(require('crypto').randomUUID())"
SOCKET_AUTH_TOKEN=

# ── Lumina Presenter Bridge ────────────────────────────────────────────────────
# Optional shared secret for POST /api/lumina/bridge.
# Set this here AND in Lumina's "Bridge Token" field (under Aether Integration settings).
# Leave empty to accept all Lumina bridge requests without token validation.
# Generate one with: node -e "console.log(require('crypto').randomUUID())"
# Bridge endpoint: POST https://aethercast.tiwaton.co.uk/api/lumina/bridge
LUMINA_BRIDGE_TOKEN=

# CORS allowed origins (comma-separated — set to your domain in production)
# Example: https://studio.yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=

# ── Android APK Signing ────────────────────────────────────────────────────────
# CRITICAL: Every APK release MUST be signed with the same keystore.
# If the keystore changes, users must manually uninstall before upgrading.
# Consult CLAUDE.md and android_apk_signing.md before changing any Android signing or build settings.
#
# Keystore file:  android/app/aethercast-release.keystore
# Key alias:      aethercast
# Validity:       10,000 days (generated 2026-04-03)
#
# KEEP A BACKUP of aethercast-release.keystore outside this repo.
# Suggested backup: USB drive, password manager attachment, or private cloud storage.
#
# To rebuild the APK (run from C:\Users\segun\source\repos\aether2 in PowerShell — no && separator):
#   1. npm run build
#   2. npx cap sync android
#   3. cd android
#   4. ./gradlew assembleRelease
#   5. cd ..
#   6. cp android/app/build/outputs/apk/release/app-release.apk public/downloads/aethercast-camera.apk
#
# Android SDK path (required — not committed to git):
#   Write android/local.properties with: sdk.dir=C\:\\Users\\segun\\AppData\\Local\\Android\\Sdk
ANDROID_KEYSTORE_PATH=android/app/aethercast-release.keystore
ANDROID_KEY_ALIAS=aethercast
