{
  "productName": "Selton Studio",
  "version": "1.0.20",
  "identifier": "com.selton.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Selton Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Coolzymccooy/AetherCast/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFODRERDMxODBFQjQ0ODUKUldTRlJPdUFNZDJFL3FDbmJXTy9jTlNmNjhPOERnV1hEREhkcEFNUTBFMVBQZTkzVmxjRjlCTHUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Professional broadcast studio for live streaming",
    "longDescription": "Aether Studio is a professional broadcast workstation with GPU-accelerated streaming, multi-destination output, AI-powered scene direction, and real-time audio processing."
  }
}
